# Database
# DATABASE_URL is the direct connection — used by `prisma migrate`, the seed
# script, and anything that needs to open more than one connection.
DATABASE_URL="postgresql://neuromarket:neuromarket@localhost:5432/neuromarket?schema=public"
# DATABASE_URL_POOLED is optional. On serverless (Vercel / AWS Lambda) point
# this at your pooled endpoint (pgbouncer transaction mode, Prisma Accelerate,
# or your provider's pooler — Neon `?pgbouncer=true&connection_limit=1`,
# Supabase port 6543, etc.) so runtime queries survive cold-start fan-out.
# Migrations still go through DATABASE_URL.
# DATABASE_URL_POOLED=""

# NextAuth — generate via: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Application
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# YooKassa — see README "YooKassa configuration".
# YOOKASSA_MODE: "test" for sandbox (test_* keys), "live" for production
# (live_* keys). In production the live secret must NEVER be a test_* key.
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
YOOKASSA_MODE="test"

# Commission tuning
PLATFORM_FEE_PERCENT="10"
PROCESSING_FEE_PERCENT="2.9"
PROCESSING_FEE_FIXED_CENTS="30"

# Email (TZ §6.6).
#   console — dev only, prints to stdout (no real delivery)
#   resend  — production, requires EMAIL_RESEND_API_KEY
#   smtp    — requires nodemailer (not bundled by default) + EMAIL_SMTP_URL
EMAIL_PROVIDER="console"
EMAIL_FROM=""
EMAIL_RESEND_API_KEY=""
EMAIL_SMTP_URL=""

# Cron (TZ §6.1) — bearer token required to invoke /api/cron/* in production.
CRON_SECRET=""

# Encryption (TZ §6.2). Format: "1:<secret1>;2:<secret2>" — newest version
# highest. New ciphertext is written with the newest; older rows are decrypted
# with the corresponding version. To rotate, append a new version and re-encrypt.
# Generate: openssl rand -base64 32
ENCRYPTION_KEYS=""

# Storage (TZ §6.5). "local" writes to ./uploads/ (dev). "s3" is any
# S3-compatible service (AWS S3, Cloudflare R2, Yandex Object Storage).
STORAGE_PROVIDER="local"
STORAGE_S3_ENDPOINT=""
STORAGE_S3_REGION=""
STORAGE_S3_BUCKET=""
STORAGE_S3_ACCESS_KEY=""
STORAGE_S3_SECRET_KEY=""

# Rate limiting (TZ §6.4). Optional. When set, the rate limiter uses Upstash
# Redis REST (distributed, survives serverless cold starts). Without them, the
# limiter falls back to in-process memory (fine for single-instance deploys).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Observability (TZ §9). All optional.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
LOG_LEVEL=""

# OAuth providers (optional). Each provider button on /sign-in appears only
# when the matching credentials are present.
#
# Google: https://console.cloud.google.com/apis/credentials → Create OAuth
# client ID → Web application. Authorized redirect URI:
#   <APP_URL>/api/auth/callback/google
# For local dev also add http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple Sign-In: requires Apple Developer Program ($99/yr).
#   1. https://developer.apple.com/account/resources/identifiers/list
#      → register an App ID with "Sign in with Apple" capability,
#      → create a Services ID (APPLE_CLIENT_ID), enable Sign in with Apple,
#      → set return URL to <APP_URL>/api/auth/callback/apple.
#   2. https://developer.apple.com/account/resources/authkeys/list
#      → create a Key with "Sign in with Apple" enabled,
#      → download the .p8 file (APPLE_PRIVATE_KEY = entire file contents,
#         multi-line OK), copy the Key ID (APPLE_KEY_ID),
#      → copy your Team ID from the top-right of developer.apple.com (APPLE_TEAM_ID).
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
